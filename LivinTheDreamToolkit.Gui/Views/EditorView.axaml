<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:LivinTheDreamToolkit.Gui.Models"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="LivinTheDreamToolkit.Gui.Views.EditorView">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PreviewOverlayBrush">#CC000000</SolidColorBrush>
    </UserControl.Resources>

    <Grid>
        <Image Source="avares://LivinTheDreamToolkit.Gui/Assets/background.jpg"
               Stretch="UniformToFill"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch" />

        <Grid ColumnDefinitions="320,*">
            <Grid Grid.Column="0">
                <Border Background="#AA000000" />

                <DockPanel LastChildFill="True" Margin="0">

                    <Grid DockPanel.Dock="Top" Margin="16,16,16,8"
                          ColumnDefinitions="Auto,*">
						<Button Grid.Column="0"
                                Name="BackButton"
                                Content="◀"
                                Width="32" Height="32"
                                Padding="0"
                                FontSize="14"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                ToolTip.Tip="Back to folder picker"
                                Background="#33FFFFFF"
                                Foreground="White"
                                BorderBrush="#66FFFFFF"
                                BorderThickness="1"
								CornerRadius="16"
                                Click="BackButton_Click" />

                        <TextBlock Grid.Column="1"
                                   Text="UGC Editor"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Grid>

                    <Border DockPanel.Dock="Top"
                            Height="2"
                            Background="White"
                            Margin="12,4,12,8"
                            Opacity="0.8" />

                    <TextBlock DockPanel.Dock="Top"
                               Name="FolderPathText"
                               Margin="16,0,16,8"
                               FontSize="11"
                               Foreground="#CCCCCC"
                               TextTrimming="CharacterEllipsis" />

                    <ListBox Name="FileList"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             SelectionChanged="FileList_SelectionChanged">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="16,10" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="BorderBrush" Value="#55FFFFFF" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                            </Style>
                        </ListBox.Styles>

                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="models:UgcTextureEntry">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding DisplayName}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="★"
                                               FontSize="12"
                                               Foreground="#FFD27F"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding HasThumb}"
                                               ToolTip.Tip="Has thumbnail file" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Grid>

            <Grid Grid.Column="1" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PreviewOverlayBrush}"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="2">
                    <Grid>
                        <TextBlock Name="PlaceholderText"
                                   Text="Selected Texture displays in this box"
                                   FontSize="28"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />

                        <!-- The actual texture -->
                        <Image Name="PreviewImage"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="16"
                               IsVisible="False" />
                    </Grid>
                </Border>

                <TextBlock Grid.Row="1"
                           Name="StatusText"
                           Margin="4,10,4,0"
                           FontSize="13"
                           Foreground="White"
                           TextWrapping="Wrap" />

				<Grid Grid.Row="2" Margin="0,12,0,0" ColumnDefinitions="*,16,*">
					<Button Grid.Column="0"
							Name="ImportButton"
							Content="Import"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Center"
							VerticalContentAlignment="Center"
							Height="56"
							FontSize="22"
							FontWeight="SemiBold"
							Background="#55000000"
							Foreground="White"
							BorderBrush="White"
							BorderThickness="1"
							CornerRadius="8"
							IsEnabled="False"
							Click="ImportButton_Click" />
					<Button Grid.Column="2"
							Name="ExportButton"
							Content="Export"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Center"
							VerticalContentAlignment="Center"
							Height="56"
							FontSize="22"
							FontWeight="SemiBold"
							Background="#55000000"
							Foreground="White"
							BorderBrush="White"
							BorderThickness="1"
							CornerRadius="8"
							IsEnabled="False"
							Click="ExportButton_Click" />
				</Grid>
            </Grid>
        </Grid>
    </Grid>

</UserControl>
